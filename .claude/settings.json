{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(./gradlew test)",
      "Bash(./gradlew compileKotlin)",
      "Bash(./gradlew bootJar)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./docker/.env)",
      "Read(./credentials.json)",
      "Read(./secrets.json)",
      "Read(./docker/certbot/conf/**)",
      "Bash(rm -rf *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout -- *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/build_checker.sh"
          }
        ]
      }
    ]
  }
}
